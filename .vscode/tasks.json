{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "FIFO: Simulate",
            "type": "shell",
            "command": "make sim",
            "options": {
                "cwd": "${workspaceFolder}/async_fifo"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "FIFO: Open Waveform (GTKWave)",
            "type": "shell",
            "command": "make wave",
            "options": {
                "cwd": "${workspaceFolder}/async_fifo"
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "FIFO: Clean",
            "type": "shell",
            "command": "make clean",
            "options": {
                "cwd": "${workspaceFolder}/async_fifo"
            },
            "problemMatcher": []
        }
    ]
}
